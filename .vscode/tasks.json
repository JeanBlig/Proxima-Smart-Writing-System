{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Program (with OCR + LLM)",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/std:c++17",
                "/MD",
                "/I",
                "C:/vcpkg/installed/x64-windows/include",
                "/I",
                "C:/Users/Change me/llama.cpp/include",
                "/I",
                "C:/Users/Change me/llama.cpp/ggml/include",
                "/I",
                "C:/Users/Change me/llama.cpp/common",
                "AppLayer/AppLayer.cpp",
                "WindowAPI/Window.cpp",
                "Core/LLM/Llama.cpp",
                "/FeDependencies/Proxima.exe",
                "/link",
                "/INCREMENTAL:NO",
                "user32.lib",
                "gdi32.lib",
                "advapi32.lib",
                "shell32.lib",
                "C:/vcpkg/installed/x64-windows/lib/tesseract55.lib",
                "C:/vcpkg/installed/x64-windows/lib/leptonica-1.85.0.lib",
                "C:/Users/Change me/llama.cpp/build/src/Release/llama.lib",
                "C:/Users/Change me/llama.cpp/build/ggml/src/Release/ggml-cpu.lib"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build Dependencies/Proxima.exe with AppLayer, WindowAPI, Tesseract OCR, and llama.cpp"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        }
    ]
}
